# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=https://your-frontend-url.vercel.app


# ─── MongoDB ──────────────────────────────────────────
# LOCAL MongoDB (works out of the box if MongoDB is installed)
MONGODB_URI=mongodb+srv://solankitushar208:solankitushar208@cluster0.vhvpktw.mongodb.net/?appName=Cluster0
# ─── JWT (pre-filled — change in production!) ─────────
JWT_SECRET=zinger_jwt_secret_key_change_in_production_2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=zinger_refresh_secret_key_different_from_above_2024
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (leave blank to skip — app still works) ────
# To enable: get a Gmail App Password from myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@zinger.in

# ─── Cloudinary (leave blank to skip image upload) ────
# Get free keys at cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Razorpay (leave blank to use COD only) ───────────
# Get test keys at dashboard.razorpay.com (free)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Stripe (optional alternative to Razorpay) ────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── OpenAI (leave blank to disable AI chatbot) ───────
# Get key at platform.openai.com (~$0.01 per session)
OPENAI_API_KEY=

# ─── Google Maps (leave blank for placeholder map) ────
GOOGLE_MAPS_API_KEY=

# ─── Admin account created by: npm run seed ───────────
ADMIN_EMAIL=admin@zinger.in
ADMIN_PASSWORD=Admin@123456
